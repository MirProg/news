# ═══════════════════════════════════════════
# ORACLE SPORTS — Environment Configuration
# ═══════════════════════════════════════════

# Server Ports
PORT=4000
FRONTEND_PORT=3000

# Ollama (Local AI)
OLLAMA_BASE_URL=http://localhost:11434/v1
WRITER_MODEL=mistral-nemo
PREDICTOR_MODEL=qwen2.5:7b-instruct
HEADLINE_MODEL=phi3.5
EMBEDDING_MODEL=nomic-embed-text

# ChromaDB (Vector Store)
CHROMADB_URL=http://localhost:8000

# Kokoro TTS
KOKORO_URL=http://localhost:8880

# The Odds API (free tier — 500 req/month)
# Sign up: https://the-odds-api.com
THE_ODDS_API_KEY=your_free_key_here

# Daemon Schedules (cron expressions)
DAEMON_INTERVAL=0 */6 * * *
AFTERMATH_INTERVAL=*/30 * * * *

# Article Quality
MIN_ARTICLE_WORDS=900
MAX_ARTICLE_WORDS=1400

# File Paths
IMAGE_CACHE_DIR=./imageCache
AUDIO_DIR=./backend/public/audio
LOG_DIR=./logs
DB_PATH=./db/oracle_sports.db

# Stable Diffusion (optional — only if AUTOMATIC1111 is running)
SD_API_URL=http://localhost:7860

# Environment
NODE_ENV=production
